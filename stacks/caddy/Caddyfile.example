# Rendered to Caddyfile by scripts/install-stacks.sh (do not edit this file on the server).
# Variables come from setup.env — see setup.env.example.

{
    email ${ACME_EMAIL}
}

# Uptime Kuma — Caddy basic auth plus Kuma's own login after the gate
kuma.${APPS_DOMAIN} {
    basicauth {
        ${CADDY_BASIC_AUTH_USER} ${CADDY_BASIC_AUTH_HASH}
    }
    reverse_proxy uptime-kuma:3001
}

dozzle.${APPS_DOMAIN} {
    basicauth {
        ${CADDY_BASIC_AUTH_USER} ${CADDY_BASIC_AUTH_HASH}
    }
    reverse_proxy dozzle:8080
}

dockge.${APPS_DOMAIN} {
    basicauth {
        ${CADDY_BASIC_AUTH_USER} ${CADDY_BASIC_AUTH_HASH}
    }
    reverse_proxy dockge:5001
}
