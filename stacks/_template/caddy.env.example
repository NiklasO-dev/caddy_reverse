# Copy to caddy.env when adding a manual app under /opt/stacks/<folder-name>/
#
# Subdomain defaults to the folder name: /opt/stacks/myapp -> https://myapp.<APPS_DOMAIN>
# SUBDOMAIN=myapp
#
# Required if compose.yml does not expose a single port:
PORT=8080
#
# Defaults to container_name from compose.yml, else folder name:
# UPSTREAM=myapp
#
# Set to false to skip Caddy basic auth (not recommended for admin UIs):
# BASIC_AUTH=true
