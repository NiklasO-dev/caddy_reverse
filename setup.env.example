# Copy to setup.env and edit on the VPS as root BEFORE setup_v2.sh.
# setup.env is gitignored and stays on your server only.
#
#   cp setup.env.example setup.env
#   nano setup.env          # nano is installed by setup_v2.sh (or: apt install nano)

# ── DNS / TLS (wildcard: *.${APPS_DOMAIN} → your VPS IP) ──
APPS_DOMAIN=apps.example.com
ACME_EMAIL=admin@example.com

# ── Host hardening (setup_v2.sh only) ──
NEW_USER=deploy
SSH_PORT=2222
TIMEZONE=Europe/Berlin

# One or more SSH public keys (multi-line in quotes is OK)
SSH_PUBLIC_KEYS="ssh-ed25519 AAAA... you@machine"

# ── Caddy basic auth (shared gate for Kuma, Dozzle, Dockge) ──
# Generate on any machine with Docker:
#   docker run --rm caddy caddy hash-password
# Use single quotes so $ in the hash is not expanded when this file is sourced:
#   CADDY_BASIC_AUTH_HASH='$2a$14$...'
# Or leave empty — setup_v2.sh / install-stacks.sh will prompt after Docker is installed.
CADDY_BASIC_AUTH_USER=admin
CADDY_BASIC_AUTH_HASH=''
