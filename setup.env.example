# Copy to setup.env, edit, then run setup_v2.sh as root on the VPS.
# setup.env is gitignored and stays on your server only.
#
#   cp setup.env.example setup.env
#   vim setup.env           # or edit locally and scp; apt install nano if you prefer nano
#   bash setup_v2.sh
#
# When each variable is read:
#   Before setup_v2.sh  — must be set (script exits if missing or still a placeholder)
#   During setup_v2.sh  — optional until install-stacks runs (after Docker is installed)
#   After setup_v2.sh   — re-read by install-stacks.sh / sudo update-stacks (git pull, etc.)

# ── Before setup_v2.sh (required) ──────────────────────────────────────────
# Also used when rendering /opt/stacks/caddy/Caddyfile (end of setup_v2.sh and on reinstall).
# Point wildcard DNS *.${APPS_DOMAIN} at your VPS before starting Caddy.
APPS_DOMAIN=apps.example.com
ACME_EMAIL=admin@example.com
CADDY_BASIC_AUTH_USER=admin

# setup_v2.sh only — not read again by install-stacks.sh / update-stacks.
NEW_USER=deploy
SSH_PORT=2222
TIMEZONE=Europe/Berlin

# Public keys for NEW_USER (~/.ssh/authorized_keys). After setup_v2.sh, root SSH is
# disabled — log in with: ssh -p ${SSH_PORT} ${NEW_USER}@your-vps-ip
# One or more keys (multi-line in quotes is OK). Replace the placeholder.
SSH_PUBLIC_KEYS="ssh-ed25519 AAAA... you@machine"

# ── During setup_v2.sh (optional beforehand) ───────────────────────────────
# Used when install-stacks.sh renders the Caddyfile (runs near the end of setup_v2.sh,
# and again on sudo update-stacks). Generate on any machine with Docker:
#   docker run --rm caddy caddy hash-password
# Use single quotes so $ in the hash is not expanded when this file is sourced:
#   CADDY_BASIC_AUTH_HASH='$2a$14$...'
# If empty: setup_v2.sh prompts after Docker is installed (needs a TTY).
# Pre-set this for non-interactive runs or to avoid re-prompting on reinstall.
CADDY_BASIC_AUTH_HASH=''
